import { Field, build, <%= selectors.map(s => s.name + 'Selector').join(', ') %> } from './selector.js';
import { Client } from './client.js';
import * as model from './model.js';

<% ops.forEach(function(op) { %>
export class <%= op.name_pascal %> {
    private field: Field;

    constructor() {
        this.field = new Field("<%= op.name %>");
    }

<% op.args.forEach(function(a) { %>
    <%= a.name %>(v: <%= a.is_primitive ? a.type : 'model.' + a.type %>) {
        this.field.args["<%= a.name %>"] = {
            arg: v,
            arg_type: "<%= a.gql_type %>",
        };
        return this;
    }
<% }); %>

<% if (!op.return_is_scalar) { %>
    select(sel: <%= op.return_name %>Selector) {
        this.field.children.push(...sel.getField().children);
        return this;
    }
<% } %>

    build(): [string, Record<string, any>] {
        return build(this.field, "<%= op.kind %>");
    }

    async do(client: Client): Promise<<%= op.return_is_primitive ? op.return_type : 'model.' + op.return_type %> | null> {
        const [query, variables] = this.build();
        const data = await client.do(query, variables);
        if (!data) return null;
        return data["<%= op.name %>"] as <%= op.return_is_primitive ? op.return_type : 'model.' + op.return_type %>;
    }
}
<% }); %>
